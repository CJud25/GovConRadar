__pycache__/
*.pyc
venv/
.venv/
.env
.pytest_cache/
outputs/
data_raw/
data_processed/
SAM.gov data/
# Guardrail: never publish anything dropped under data/ EXCEPT the committed
# default sample (data/sample/). Stops a stray raw pull with CO contact PII from
# being committed silently.
data/*
# Baked top-50 capture briefs: local + re-derivable (rebake_data.bake_briefs) — never
# committed, never shipped. Explicit intent even under the data/* guard above (S31).
data/briefs/
!data/sample/
# Committed reference inputs (e.g. the GSA PSC manual CSVs) — small, public-domain,
# and load-bearing for reference_tables.build_psc_lookup.
!data/reference/
# Hand-labeling worksheets (committed so a fresh clone exercises the empty-label
# path; the filled verdicts are the measured-trust ground truth). PRIVATE-only —
# the deploy overlay never ships data/labels/.
!data/labels/
# Local quarantine for UNVERIFIED / superseded label data (e.g. the archived bulk-fill link
# worksheet + pre-migration outcome snapshots) — audit trail only, MUST never ship.
data/labels/archive/
# Data DIET: the FULL published snapshot (data/powerbi/, ~44 MB CSV) is NOT
# committed — it is fetched locally via scripts/download_data.py. A fresh clone has
# no data/powerbi/ and boots on the committed data/sample/ subsample instead.
# (data/sample/ ships CSV + Parquet; validate_data.py checks CSV<->Parquet parity.)

# pipeline_demo ETL output is regenerated by run_all.py (data DIET — the committed
# input is the synthetic fixture under pipeline_demo/fixtures/, not the output).
pipeline_demo/output/

# Local/dev artifacts — never publish. Runtime logs (etl_run.log) stay ignored, but
# logs/LOG.md is the ralph build log (cross-iteration memory) and MUST be tracked.
logs/*
!logs/LOG.md
# Editable-install / packaging build artifacts (`pip install -e .`)
*.egg-info/
build/
dist/
# Power BI Desktop local settings/cache (machine-bound; user-local)
.pbi/
.superpowers/
# Release asset build output (published via gh release, never committed)
powerbi-snapshot.zip
